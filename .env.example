# OpenRouter API key — get one at https://openrouter.ai/keys
# For production, prefer a backend proxy so the key is not in the browser bundle.
# VITE_OPENROUTER_API_KEY=sk-or-v1-...

# Optional: proxy URL. App POSTs { "prompt": "..." } and expects { "text": "..." }.
# Local Node proxy: npm run proxy → http://localhost:3001/api
# Cloudflare Pages: https://your-project.pages.dev/api
# Legacy name still supported: VITE_ANTHROPIC_PROXY
# VITE_OPENROUTER_PROXY=http://localhost:3001/api

# OpenRouter model slug (see https://openrouter.ai/models). Default:
# VITE_OPENROUTER_MODEL=anthropic/claude-sonnet-4.6

# Optional max completion tokens (default 16384; capped at 128000).
# VITE_OPENROUTER_MAX_TOKENS=16384

# Override chat URL only if OpenRouter changes routing (default: https://openrouter.ai/api/v1/chat/completions).
# VITE_OPENROUTER_API_URL=https://openrouter.ai/api/v1/chat/completions

# Optional OpenRouter attribution headers (https://openrouter.ai/docs/app-attribution)
# VITE_OPENROUTER_HTTP_REFERER=https://your-site.example
# VITE_OPENROUTER_APP_TITLE=My school curriculum app

# Optional: server PDF POST URL (body: { html, filename }). If unset, /pdf is inferred only when
# VITE_OPENROUTER_PROXY (or legacy VITE_ANTHROPIC_PROXY) points at localhost:3001 + /api.
# VITE_PDF_ENDPOINT=http://localhost:3001/pdf

# Optional break-glass: Bearer for PUT /api/page-settings and POST /api/page-settings-logo (local or Pages)
# PAGE_SETTINGS_ADMIN_TOKEN=your-long-random-secret

# Magic-link admin (local proxy + Cloudflare): HS256 session cookie
# JWT_SECRET=another-long-random-secret
# BREVO_API_KEY=xkeysib-...
# MAGIC_LINK_FROM_EMAIL=noreply@your-verified-domain.example
# MAGIC_LINK_FROM_NAME=Curriculum admin
# ADMIN_EMAIL_ALLOWLIST=admin@school.org,ops@school.org
# APP_ORIGIN=http://127.0.0.1:5173

# PostHog US (optional; public build vars on Pages)
# VITE_PUBLIC_POSTHOG_KEY=phc_...
# VITE_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Dev: fake curriculum without calling the API.
VITE_USE_MOCK_CLAUDE=true
